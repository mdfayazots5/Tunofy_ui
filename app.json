{
  "expo": {
    "name": "Tunofy",
    "slug": "tunofy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0F0F14"
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
